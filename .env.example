# Copiez ce fichier en .env et remplissez les valeurs
# .env est gitignore : vos secrets ne seront jamais uploadés

# URL PostgreSQL (Neon, Supabase, Railway, local…)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# (optionnel - déjà détecté automatiquement en prod)
# NODE_ENV=production
